{
  "name": "@m13v/seo-components",
  "version": "0.16.1",
  "scripts": {
    "build:css": "tailwind -i src/_build.css -o dist/styles.css --minify",
    "bump:consumers": "bash scripts/bump-consumers.sh",
    "prepublishOnly": "npm run build:css",
    "postpublish": "npm run bump:consumers"
  },
  "description": "42 animated React components for programmatic SEO pages. Remotion video, Magic UI style animations, trust signals, JSON-LD helpers. Teal/cyan brand, supports light and dark themes.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*",
    "./lib/*": "./src/lib/*",
    "./server": "./src/server.ts",
    "./next": {
      "types": "./src/next.d.ts",
      "default": "./src/next.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles.src.css": "./src/styles.css"
  },
  "files": [
    "src",
    "dist",
    "registry.json"
  ],
  "keywords": [
    "seo",
    "components",
    "react",
    "nextjs",
    "framer-motion",
    "remotion",
    "magic-ui",
    "animated",
    "programmatic-seo",
    "json-ld"
  ],
  "author": "m13v",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m13v/seo-components.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@assistant-ui/react": ">=0.7",
    "@google/generative-ai": ">=0.24",
    "@remotion/player": ">=4",
    "@supabase/supabase-js": ">=2",
    "framer-motion": ">=11",
    "lottie-react": ">=2",
    "next": ">=14",
    "posthog-js": ">=1.100",
    "react": ">=18",
    "react-dom": ">=18",
    "remotion": ">=4"
  },
  "peerDependenciesMeta": {
    "remotion": {
      "optional": true
    },
    "@remotion/player": {
      "optional": true
    },
    "lottie-react": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    },
    "@assistant-ui/react": {
      "optional": true
    },
    "posthog-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
